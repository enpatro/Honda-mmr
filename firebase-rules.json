{
  "rules": {
    ".read": "auth != null",
    "userProfiles": {
      "$uid": {
        ".write": "auth != null && (auth.uid == $uid || (root.child('userRoles').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'e.patro@honda.hmsi.in'))"
      }
    },
    "userRoles": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && (root.child('userRoles').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'e.patro@honda.hmsi.in')"
      }
    },
    "machines": {
      "$id": {
        ".write": "auth != null && (newData.exists() || (root.child('userRoles').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'e.patro@honda.hmsi.in'))"
      }
    },
    "parts": {
      "$id": {
        ".write": "auth != null && (newData.exists() || (root.child('userRoles').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'e.patro@honda.hmsi.in'))"
      }
    },
    "history": {
      "$id": {
        ".write": "auth != null && (newData.exists() || (root.child('userRoles').child(auth.uid).child('role').val() == 'admin' || auth.token.email == 'e.patro@honda.hmsi.in'))"
      }
    },
    "imports": {
      "$id": {
        ".write": "auth != null"
      }
    }
  }
}